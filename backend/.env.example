# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kaystcx_user
DB_PASSWORD=kaystcx_password
DB_NAME=kaystcx

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_SECRET_KEY=your_stellar_secret_key_here
STELLAR_ISSUER_PUBLIC_KEY=your_stellar_public_key_here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentry Configuration
SENTRY_DSN=https://your-key@sentry.io/project-id
ENABLE_SENTRY=false

# Storage Configuration (S3/MinIO)
# Set STORAGE_REQUIRED=false to disable storage requirement
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=kaystcx
STORAGE_REQUIRED=true

# Audit Log Configuration
# Number of days to retain audit logs before automatic cleanup
# Cleanup runs daily at midnight
AUDIT_RETENTION_DAYS=90

# Duplicate Detection Configuration
# Similarity threshold for duplicate detection (0.0 to 1.0)
DUPLICATE_DETECTION_THRESHOLD=0.7
# Enable fuzzy matching for duplicate detection
DUPLICATE_DETECTION_FUZZY_MATCHING=true
# Time window in days to check for duplicates (e.g., 30 = check last 30 days)
DUPLICATE_DETECTION_TIME_WINDOW_DAYS=30
# Field weights for similarity calculation (0.0 to 1.0)
DUPLICATE_DETECTION_EMAIL_WEIGHT=0.5
DUPLICATE_DETECTION_NAME_WEIGHT=0.3
DUPLICATE_DETECTION_TITLE_WEIGHT=0.2
